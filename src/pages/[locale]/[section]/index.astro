---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/Container.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import BlogCard from '@/components/BlogCard.astro';
import { siteConfig } from '@/config/site';
import { locales, getMessages, intlLocales, type Locale } from '@/i18n';
import { getContentByLocale, getSlug } from '@/lib/posts';

export async function getStaticPaths() {
  const paths = [];
  const nonEnLocales = locales.filter((l) => l !== 'en');
  for (const locale of nonEnLocales) {
    for (const s of siteConfig.sections) {
      paths.push({
        params: { locale, section: s.id },
        props: { locale, section: s },
      });
    }
  }
  return paths;
}

const { locale, section } = Astro.props as { locale: Locale; section: (typeof siteConfig.sections)[number] };
const m = getMessages(locale);
const entries = await getContentByLocale(section.id, locale);
const title = m.nav[section.labelKey] ?? section.labelKey;
---

<Layout title={`${title} | ${siteConfig.name}`}>
  <Container class="px-4">
    <div class="mt-8">
      <h1 class="text-2xl font-semibold mb-6 text-[var(--color-link)]">{title}</h1>
      <BlogGrid>
        {
          entries.map((entry: any) => (
            <BlogCard
              slug={getSlug(entry.id)}
              title={entry.data.title}
              date={entry.data.date}
              locale={intlLocales[locale]}
              basePath={`/${locale}`}
              section={section.id}
              pinned={entry.data.pinned}
            />
          ))
        }
      </BlogGrid>
    </div>
  </Container>
</Layout>
